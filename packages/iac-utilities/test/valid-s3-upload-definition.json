{
  "$schema": "json-schemas/s3-upload-definition-schema.json",
  "definitions": [
    {
      "include": [
        "*.css",
        "*.js",
        "*.js.map",
        "*.woff2",
        "*.woff",
        "*.ttf",
        "*.otf",
        "*.svg",
        "*.png",
        "*.jpeg",
        "*.jpg",
        "*.ico",
        "*.gif"
      ],
      "cacheControl": "max-age=31536000"
    },
    {
      "include": ["*.html"],
      "cacheControl": "max-age=0, s-maxage=300",
      "contentType": "text/html; charset=utf-8*"
    },
    {
      "include": ["*.json"],
      "cacheControl": "max-age=604800"
    }
  ]
}
