{
  "name": "@shiftcode/eslint-config-recommended",
  "version": "7.0.0-pr254.14",
  "description": "default shiftcode config for eslint",
  "repository": "https://github.com/shiftcode/sc-commons-public",
  "license": "MIT",
  "author": "shiftcode GmbH <team@shiftcode.ch>",
  "sideEffects": false,
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./angular": {
      "types": "./dist/angular/index.d.ts",
      "default": "./dist/angular/index.js"
    }
  },
  "scripts": {
    "build": "rm -rf ./dist && tsc",
    "format": "prettier --write .",
    "lint": "eslint --fix --cache .",
    "lint:ci": "eslint .",
    "prepublish": "node ../publish-helper/dist/prepare-dist.js",
    "test": "echo 'no test'",
    "test:ci": "echo 'No tests'"
  },
  "dependencies": {
    "@eslint/js": "^9.37.0",
    "@shiftcode/eslint-plugin-rules": "^6.0.0-pr254.14",
    "eslint": "^9.37.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-simple-import-sort": "^12.1.1",
    "eslint-plugin-unused-imports": "^4.2.0",
    "typescript-eslint": "8.46.0"
  },
  "devDependencies": {
    "angular-eslint": "^20.5.1"
  },
  "peerDependencies": {
    "angular-eslint": "^20.5.1 || ^21.0.0"
  },
  "peerDependenciesMeta": {
    "angular-eslint": {
      "optional": true
    }
  },
  "engines": {
    "node": ">=24.10.2"
  },
  "publishConfig": {
    "directory": "dist"
  }
}
