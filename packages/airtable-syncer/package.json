    "@swc/core": "^1.15.11",
    "unplugin-swc": "^1.5.9"
  },
  "peerDependencies": {
    "@aws-sdk/client-sns": "^3.188.0",
    "@shiftcode/airtable-mapper": "^1.0.0 || ^0.0.0-pr254",
    "@shiftcode/inversify-logger": "^1.0.0 || ^0.0.0-pr254",
